{
  "name": "PL_Casestudy1",
  "objectId": "<object-id>",
  "properties": {
    "activities": [
      {
        "name": "Get_Landing_Files",
        "type": "GetMetadata",
        "typeProperties": {
          "fieldList": ["childItems"],
          "datasetSettings": {
            "linkedService": {
              "name": "Lakehouse_Service",
              "properties": {
                "type": "Lakehouse",
                "typeProperties": {
                  "workspaceId": "<workspace-id>",
                  "artifactId": "<lakehouse-id>",
                  "rootFolder": "Files"
                }
              }
            },
            "type": "DelimitedText",
            "typeProperties": {
              "location": {
                "type": "LakehouseLocation",
                "folderPath": "Casestudy1/Landing/Incoming"
              },
              "firstRowAsHeader": true
            }
          },
          "storeSettings": {
            "type": "LakehouseReadSettings",
            "recursive": true
          }
        }
      },

      {
        "name": "Filter_Valid_Office_Csv",
        "type": "Filter",
        "typeProperties": {
          "items": {
            "value": "@activity('Get_Landing_Files').output.childItems",
            "type": "Expression"
          },
          "condition": {
            "value": "@and(equals(item().type,'File'),startsWith(item().name,'office_'),endsWith(item().name,'.csv'))",
            "type": "Expression"
          }
        }
      },

      {
        "name": "ForEach_Valid_File",
        "type": "ForEach",
        "typeProperties": {
          "items": {
            "value": "@activity('Filter_Valid_Office_Csv').output.value",
            "type": "Expression"
          },
          "isSequential": true,
          "activities": [
            {
              "name": "Copy_to_LH",
              "type": "Copy",
              "typeProperties": {
                "source": {
                  "type": "DelimitedTextSource",
                  "additionalColumns": [
                    {
                      "name": "insert_time",
                      "value": {
                        "value": "@utcNow()",
                        "type": "Expression"
                      }
                    }
                  ],
                  "storeSettings": {
                    "wildcardFileName": {
                      "value": "@item().name",
                      "type": "Expression"
                    }
                  }
                },
                "sink": {
                  "type": "LakehouseTableSink",
                  "tableActionOption": "Upsert",
                  "upsertSettings": {
                    "keys": ["property_id"]
                  }
                }
              }
            },

            {
              "name": "Copy_to_Archive_Processed",
              "type": "Copy",
              "dependsOn": [
                {
                  "activity": "Copy_to_LH",
                  "dependencyConditions": ["Succeeded"]
                }
              ],
              "typeProperties": {
                "sink": {
                  "type": "DelimitedTextSink"
                }
              }
            },

            {
              "name": "Delete_From_Landing",
              "type": "Delete",
              "dependsOn": [
                {
                  "activity": "Copy_to_Archive_Processed",
                  "dependencyConditions": ["Succeeded"]
                }
              ]
            },

            {
              "name": "MicrosoftTeams_Notification",
              "type": "MicrosoftTeams",
              "dependsOn": [
                {
                  "activity": "Delete_From_Landing",
                  "dependencyConditions": ["Succeeded"]
                }
              ],
              "typeProperties": {
                "operationType": "SendMessageInChannel",
                "subject": "Fabric Pipeline Success",
                "content": "Pipeline executed successfully",
                "teamId": "<team-id>",
                "channelId": "<channel-id>"
              },
              "externalReferences": {
                "connection": "<connection-id>"
              }
            }
          ]
        }
      }
    ],
    "lastModifiedByObjectId": "<user-id>"
  }
}